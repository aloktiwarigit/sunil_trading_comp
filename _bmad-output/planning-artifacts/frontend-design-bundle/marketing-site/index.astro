---
// sites/marketing/src/pages/index.astro
//
// Yugma Dukaan — Sunil Trading Company marketing landing page
//
// PURE STATIC ASTRO. NOT Flutter Web. Per ADR-011, the 50× weight
// difference (50KB Astro vs 2-3MB Flutter Web) is decisive for
// Tier-3 3G connections.
//
// Bundle target: <100KB initial paint.
// First Contentful Paint target: <1 second on 3G.
// Devanagari font: subset-loaded, only the glyphs in this page's
// content + 200 most common buffer.
//
// Per locked PQ4: shop content fetched at BUILD TIME from Firestore
// via the read-only admin SDK in scripts/fetch_shop_content.ts.
// At runtime, this page is pure HTML/CSS — zero Firestore reads,
// zero JS framework runtime.

import { fetchShopContent } from '../scripts/fetch_shop_content';

// Build-time data fetch — happens during `astro build`, NOT in browser
const shopContent = await fetchShopContent('sunil-trading-company');
---

<!DOCTYPE html>
<html lang="hi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <meta name="description" content={`${shopContent.brandName} — Almirah shop in ${shopContent.marketArea}, ${shopContent.city}. Talk to ${shopContent.ownerName} on WhatsApp.`} />
  <title>{shopContent.brandName}</title>

  <!-- Subset-loaded Devanagari font (only glyphs used on this page + buffer) -->
  <link rel="preload" href="/fonts/tiro-deva-subset.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/mukta-subset.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/fraunces-italic-subset.woff2" as="font" type="font/woff2" crossorigin />

  <style is:inline>
    @font-face {
      font-family: 'Tiro Devanagari Hindi';
      src: url('/fonts/tiro-deva-subset.woff2') format('woff2');
      font-display: swap;
      unicode-range: U+0900-097F, U+0020-007F;
    }
    @font-face {
      font-family: 'Mukta';
      src: url('/fonts/mukta-subset.woff2') format('woff2');
      font-weight: 400;
      font-display: swap;
      unicode-range: U+0900-097F, U+0020-007F;
    }
    @font-face {
      font-family: 'Fraunces';
      src: url('/fonts/fraunces-italic-subset.woff2') format('woff2');
      font-style: italic;
      font-display: swap;
    }

    :root {
      --c-primary: #6B3410;
      --c-primary-deep: #4A2308;
      --c-accent: #B8860B;
      --c-bg: #FAF3E7;
      --c-bg-warmer: #F5EBD7;
      --c-surface: #FFFAF0;
      --c-text: #1F1611;
      --c-text-on-primary: #FAF3E7;
      --c-divider: rgba(107, 52, 16, 0.12);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html { -webkit-font-smoothing: antialiased; }

    body {
      font-family: 'Mukta', sans-serif;
      font-size: 15px;
      line-height: 1.6;
      color: var(--c-text);
      background: var(--c-bg);
      min-height: 100vh;
    }

    /* Paper-grain overlay — subtle, anchors the aesthetic */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4'/%3E%3CfeColorMatrix values='0 0 0 0 0.42 0 0 0 0 0.20 0 0 0 0 0.06 0 0 0 0.04 0'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      opacity: 0.5;
      pointer-events: none;
      z-index: 0;
    }

    main { position: relative; z-index: 1; }

    /* Hero */
    .hero {
      min-height: 60vh;
      background: linear-gradient(180deg, transparent 50%, rgba(31, 22, 17, 0.8) 100%),
                  radial-gradient(ellipse at center, #8B5A2B, #2C1810);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 24px 16px 32px;
      text-align: center;
      position: relative;
    }

    .hero-face {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      background: linear-gradient(135deg, #D4A574, #6B3410);
      border: 4px solid var(--c-accent);
      position: absolute;
      top: 32px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Tiro Devanagari Hindi', serif;
      font-size: 48px;
      color: var(--c-text-on-primary);
      box-shadow: 0 4px 24px rgba(0,0,0,0.4);
    }

    .hero-name {
      font-family: 'Tiro Devanagari Hindi', serif;
      font-size: 36px;
      line-height: 1.2;
      color: var(--c-text-on-primary);
      margin-bottom: 6px;
      text-shadow: 0 2px 12px rgba(0,0,0,0.5);
    }

    .hero-tagline {
      font-family: 'Fraunces', serif;
      font-style: italic;
      font-size: 16px;
      color: rgba(250, 243, 231, 0.9);
      max-width: 300px;
      margin: 0 auto;
    }

    .hero-est {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: var(--c-accent);
      letter-spacing: 0.1em;
      margin-top: 12px;
    }

    /* Greeting voice note (auto-play with mute toggle) */
    .greeting {
      background: var(--c-bg-warmer);
      border-left: 3px solid var(--c-accent);
      padding: 16px;
      margin: 16px;
      border-radius: 0 8px 8px 0;
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .greeting button {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: var(--c-accent);
      border: none;
      color: var(--c-primary-deep);
      font-size: 22px;
      cursor: pointer;
      box-shadow: 0 2px 8px rgba(74, 35, 8, 0.2);
      flex-shrink: 0;
    }

    .greeting-text {
      font-family: 'Mukta', sans-serif;
      font-size: 13px;
      color: var(--c-text);
      flex: 1;
    }

    .greeting-text strong {
      display: block;
      font-family: 'Tiro Devanagari Hindi', serif;
      font-size: 14px;
      color: var(--c-primary);
      margin-bottom: 2px;
    }

    /* CTAs */
    .cta-row {
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .cta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 16px;
      border-radius: 8px;
      font-family: 'Tiro Devanagari Hindi', serif;
      font-size: 16px;
      text-decoration: none;
      min-height: 56px;
      box-shadow: 0 2px 8px rgba(74, 35, 8, 0.15);
    }

    .cta-whatsapp {
      background: #25D366;
      color: white;
    }

    .cta-app {
      background: var(--c-primary);
      color: var(--c-text-on-primary);
    }

    /* Curated catalog preview (top 6 SKUs baked in at build time) */
    .catalog {
      padding: 24px 16px;
    }

    .catalog-header {
      font-family: 'Tiro Devanagari Hindi', serif;
      font-size: 20px;
      color: var(--c-primary);
      margin-bottom: 4px;
      text-align: center;
    }

    .catalog-sub {
      font-family: 'Fraunces', serif;
      font-style: italic;
      font-size: 12px;
      color: var(--c-accent);
      text-align: center;
      margin-bottom: 16px;
    }

    .catalog-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .catalog-item {
      background: var(--c-surface);
      border: 1px solid var(--c-divider);
      border-radius: 8px;
      overflow: hidden;
      box-shadow: 0 1px 3px rgba(74, 35, 8, 0.08);
    }

    .catalog-item-photo {
      aspect-ratio: 1;
      background: linear-gradient(135deg, #6B3410, #2C1810);
    }

    .catalog-item-info {
      padding: 8px 12px;
    }

    .catalog-item-name {
      font-family: 'Tiro Devanagari Hindi', serif;
      font-size: 13px;
      color: var(--c-text);
      line-height: 1.3;
    }

    .catalog-item-price {
      font-family: 'DM Mono', monospace;
      font-size: 14px;
      font-weight: 600;
      color: var(--c-primary);
      margin-top: 4px;
    }

    /* Visit / contact */
    .visit {
      background: var(--c-surface);
      padding: 24px 16px;
      margin-top: 24px;
    }

    .visit-info {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 0;
      border-bottom: 1px solid var(--c-divider);
    }

    .visit-info:last-child { border-bottom: none; }

    .visit-icon {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      background: var(--c-bg-warmer);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--c-accent);
      flex-shrink: 0;
    }

    .visit-text strong {
      display: block;
      font-family: 'Tiro Devanagari Hindi', serif;
      color: var(--c-primary);
      font-size: 14px;
    }

    .visit-text span {
      font-family: 'Mukta', sans-serif;
      font-size: 12px;
      color: var(--c-text);
    }

    /* Footer */
    footer {
      background: var(--c-primary-deep);
      color: var(--c-text-on-primary);
      padding: 24px 16px;
      text-align: center;
      font-family: 'Fraunces', serif;
      font-style: italic;
      font-size: 11px;
    }

    footer a {
      color: var(--c-accent);
    }
  </style>
</head>
<body>
  <main>
    <section class="hero">
      <div class="hero-face">{shopContent.ownerName.substring(0, 2)}</div>
      <div class="hero-name">{shopContent.brandName}</div>
      <div class="hero-tagline">{shopContent.taglineEnglish}</div>
      <div class="hero-est">EST. {shopContent.establishedYear} · {shopContent.marketArea.toUpperCase()}</div>
    </section>

    <section class="greeting">
      <button id="greetingPlay" aria-label="Play greeting">▶</button>
      <div class="greeting-text">
        <strong>नमस्ते जी, स्वागत है</strong>
        {shopContent.ownerName} का स्वागत संदेश सुनिए
      </div>
    </section>

    <section class="cta-row">
      <a class="cta cta-whatsapp" href={`https://wa.me/${shopContent.whatsappNumberE164.replace(/\D/g, '')}?text=${encodeURIComponent('नमस्ते सुनील भैया, मैं आपकी वेबसाइट से आया हूँ')}`}>
        सुनील भैया से अभी बात कीजिए
      </a>
      <a class="cta cta-app" href={`https://yugmalabs.ai/app/${shopContent.shopId}`}>
        दुकान खोलिए · Open the shop
      </a>
    </section>

    <section class="catalog">
      <div class="catalog-header">सुनील भैया की पसंद</div>
      <div class="catalog-sub">Curated finite shortlist · 6 picks</div>
      <div class="catalog-grid">
        {shopContent.curatedPreview.slice(0, 6).map((sku) => (
          <div class="catalog-item">
            <div class="catalog-item-photo"></div>
            <div class="catalog-item-info">
              <div class="catalog-item-name">{sku.nameDevanagari}</div>
              <div class="catalog-item-price">₹{sku.priceInr.toLocaleString('en-IN')}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="visit">
      <div class="visit-info">
        <div class="visit-icon">📍</div>
        <div class="visit-text">
          <strong>{shopContent.marketArea}</strong>
          <span>{shopContent.city}, उत्तर प्रदेश 224001</span>
        </div>
      </div>
      <div class="visit-info">
        <div class="visit-icon">⏰</div>
        <div class="visit-text">
          <strong>समय</strong>
          <span>सुबह 9 से रात 9 · रोज़</span>
        </div>
      </div>
      <div class="visit-info">
        <div class="visit-icon">📞</div>
        <div class="visit-text">
          <strong>{shopContent.whatsappNumberE164}</strong>
          <span>call · WhatsApp</span>
        </div>
      </div>
    </section>
  </main>

  <footer>
    Powered by Yugma Labs · zero commission, zero customer fees
  </footer>

  <!-- Minimal inline JS for greeting play. NO framework runtime. -->
  <script is:inline define:vars={{ greetingUrl: shopContent.greetingVoiceNoteUrl }}>
    const btn = document.getElementById('greetingPlay');
    let audio = null;
    btn?.addEventListener('click', () => {
      if (!audio) {
        audio = new Audio(greetingUrl);
        audio.play().catch(() => {});
      } else {
        audio.paused ? audio.play() : audio.pause();
      }
    });
  </script>
</body>
</html>
