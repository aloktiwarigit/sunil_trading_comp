---
// =============================================================================
// Sunil Trading Company — Full Marketing Site
//
// Design: Workshop Almanac v1.1 / Artisan Industrial
// "A digital bazaar shopfront — warm, honest, Devanagari-first."
//
// Sections:
//   1. Hero — bhaiya's face, name, tagline, voice, trust badges
//   2. भरोसा (Trust) — 23 years, GST, market presence
//   3. Catalog — occasion-tabbed product grid with WhatsApp CTAs
//   4. About — Sunil-bhaiya's story
//   5. CTA band — WhatsApp + app
//   6. Footer — address, hours, links
//
// Constraints: <100KB HTML+CSS, 5 Google Fonts, mobile-first 3G,
//              pure static Astro, no JS framework.
// =============================================================================

import BaseLayout from '../layouts/BaseLayout.astro';
import { fetchShopContent } from '../lib/fetch_shop_content';
import type { SkuPreview } from '../lib/fetch_shop_content';

const shopId = import.meta.env.SHOP_ID ?? process.env.SHOP_ID ?? 'sunil-trading-company';
const shop = await fetchShopContent(shopId);

const yearsInBusiness = new Date().getFullYear() - shop.establishedYear;
const whatsappBase = `https://wa.me/${shop.whatsappNumberE164.replace('+', '')}`;
const whatsappUrl = `${whatsappBase}?text=${encodeURIComponent(`नमस्ते ${shop.ownerName}, मुझे अलमारी देखनी है`)}`;
const appUrl = 'https://play.google.com/store/apps/details?id=ai.yugmalabs.suniltrading';
const hasVoiceNote = shop.greetingVoiceNoteUrl.length > 0;
const hasFacePhoto = shop.shopkeeperFaceUrl.length > 0;
const hasCatalog = shop.curatedPreview.length > 0;

// Build WhatsApp URL per SKU
function skuWhatsApp(skuName: string): string {
  return `${whatsappBase}?text=${encodeURIComponent(`नमस्ते ${shop.ownerName}, मुझे ${skuName} के बारे में जानना है`)}`;
}

// Group SKUs by occasion for tabbed display
const occasions = [
  { id: 'shaadi', label: 'शादी के लिए', labelEn: 'Wedding' },
  { id: 'naya-ghar', label: 'नए घर के लिए', labelEn: 'New Home' },
  { id: 'budget', label: 'बजट में', labelEn: 'Budget-Friendly' },
];
---

<BaseLayout title={`${shop.brandName} — ${shop.brandNameEnglish}`}>

  <!-- ═══════════════════════════════════════════════════════
       §1 HERO — The digital shopfront entrance
       ═══════════════════════════════════════════════════════ -->
  <header class="hero">
    <div class="hero-bg-pattern"></div>
    <div class="hero-content">
      <!-- Bhaiya's face -->
      <div class="hero-photo-wrap">
        {hasFacePhoto ? (
          <img
            src={shop.shopkeeperFaceUrl}
            alt={shop.ownerName}
            class="hero-photo"
            width="140"
            height="140"
            loading="eager"
          />
        ) : (
          <div class="hero-photo-fallback">
            <span class="hero-initials">{shop.brandName.charAt(0)}</span>
          </div>
        )}
        <div class="hero-photo-ring"></div>
      </div>

      <h1 class="hero-name">{shop.brandName}</h1>
      <p class="hero-name-en">{shop.brandNameEnglish}</p>

      <p class="hero-tagline">{shop.taglineDevanagari}</p>

      <!-- Trust badges inline -->
      <div class="hero-badges">
        <span class="badge">
          <span class="badge-icon">🏪</span>
          {yearsInBusiness} साल
        </span>
        <span class="badge-dot">·</span>
        <span class="badge">{shop.marketArea}</span>
        {shop.gstNumber && (
          <>
            <span class="badge-dot">·</span>
            <span class="badge badge-gst">GST पंजीकृत</span>
          </>
        )}
      </div>

      <!-- Voice greeting -->
      {hasVoiceNote && (
        <div class="hero-voice">
          <audio id="greetingAudio" preload="auto">
            <source src={shop.greetingVoiceNoteUrl} type="audio/mp4" />
          </audio>
          <button class="btn-voice" id="voiceBtn" onclick="toggleVoice()">
            <span class="voice-wave">🎤</span> {shop.ownerName} की आवाज़ सुनिए
          </button>
        </div>
      )}

      <!-- Primary CTA -->
      <div class="hero-ctas">
        <a href={whatsappUrl} class="btn btn-whatsapp hero-cta" target="_blank" rel="noopener">
          <svg class="wa-icon" viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          {shop.ownerName} से बात कीजिए
        </a>
        <a href={appUrl} class="btn btn-outline hero-cta hero-cta-app" target="_blank" rel="noopener">
          दुकान ऐप खोलिए
        </a>
      </div>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════════════════
       §2 भरोसा (TRUST) — Why this shop, why 23 years
       ═══════════════════════════════════════════════════════ -->
  <section class="section trust-section">
    <div class="section-inner">
      <h2 class="section-title">भरोसे की दुकान</h2>
      <p class="section-subtitle">A shop built on trust, not advertising</p>
      <hr class="brass-divider" />

      <div class="trust-grid">
        <div class="trust-card">
          <span class="trust-icon">🏛️</span>
          <h3 class="trust-title">{yearsInBusiness} साल का अनुभव</h3>
          <p class="trust-desc">{shop.establishedYear} से हैरिंगटनगंज बाज़ार में — पिता जी के ज़माने से आपकी सेवा में</p>
        </div>
        <div class="trust-card">
          <span class="trust-icon">🤝</span>
          <h3 class="trust-title">पूरे परिवार की पसंद</h3>
          <p class="trust-desc">शादी हो, नया घर हो, या पुरानी अलमारी बदलनी हो — हर ज़रूरत के लिए सही सलाह</p>
        </div>
        <div class="trust-card">
          <span class="trust-icon">💬</span>
          <h3 class="trust-title">सीधी बात, सही दाम</h3>
          <p class="trust-desc">कोई छुपी बात नहीं — जो दाम बताएँगे, वही अंतिम। WhatsApp पर भी पूछ सकते हैं</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       §3 CATALOG — Products by occasion
       ═══════════════════════════════════════════════════════ -->
  <section class="section catalog-section" id="catalog">
    <div class="section-inner">
      <h2 class="section-title">भैया की पसंद</h2>
      <p class="section-subtitle">Hand-picked by Sunil-bhaiya for every occasion</p>
      <hr class="brass-divider" />

      {hasCatalog ? (
        <div class="catalog-grid">
          {shop.curatedPreview.map((sku: SkuPreview) => (
            <div class="sku-card">
              <div class="sku-photo-wrap">
                {sku.thumbnailUrl ? (
                  <img
                    src={sku.thumbnailUrl}
                    alt={sku.nameDevanagari}
                    class="sku-photo"
                    width="400"
                    height="300"
                    loading="lazy"
                  />
                ) : (
                  <div class="sku-photo-placeholder">
                    <span class="sku-placeholder-icon">🗄️</span>
                  </div>
                )}
              </div>
              <div class="sku-body">
                <h3 class="sku-name">{sku.nameDevanagari}</h3>
                <p class="sku-name-en">{sku.nameEnglish}</p>
                <p class="sku-price">₹{sku.priceInr.toLocaleString('en-IN')}</p>
                <a
                  href={skuWhatsApp(sku.nameDevanagari)}
                  class="btn btn-whatsapp sku-cta"
                  target="_blank"
                  rel="noopener"
                >
                  भैया से पूछिए
                </a>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div class="catalog-empty">
          <span class="catalog-empty-icon">🗄️</span>
          <p class="catalog-empty-text">जल्द ही — भैया अपनी पसंद चुन रहे हैं</p>
        </div>
      )}

      <!-- Full catalog CTA -->
      <div class="catalog-cta-wrap">
        <a href={appUrl} class="btn btn-accent catalog-cta" target="_blank" rel="noopener">
          पूरा कैटलॉग देखिए →
        </a>
        <p class="catalog-cta-note">ऐप में 50+ अलमारियाँ, सभी की फ़ोटो और दाम</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       §4 ABOUT — Sunil-bhaiya's story
       ═══════════════════════════════════════════════════════ -->
  <section class="section about-section">
    <div class="section-inner">
      <h2 class="section-title">हमारी दुकान की कहानी</h2>
      <p class="section-subtitle">The story of our shop</p>
      <hr class="brass-divider" />

      <div class="about-content">
        <div class="about-text">
          <p class="about-para">
            {shop.ownerName} {shop.establishedYear} से {shop.marketArea} में अलमारी बेच रहे हैं।
            पहले पिता जी के साथ शुरू किया, अब अपने बेटे के साथ मिलकर दुकान चलाते हैं।
          </p>
          <p class="about-para">
            गोदरेज, त्रिवेणी, और लोकल — हर बजट और ज़रूरत के हिसाब से अलमारी मिलेगी।
            भैया की खासियत: सही सलाह और इमानदार दाम। कोई ज़बरदस्ती नहीं, कोई झूठा वादा नहीं।
          </p>
          <p class="about-para about-highlight">
            "जो ग्राहक एक बार आता है, वो अगली बार भी यहीं आता है" — यही हमारा भरोसा है।
          </p>
        </div>
        <div class="about-stats">
          <div class="stat">
            <span class="stat-number">{yearsInBusiness}+</span>
            <span class="stat-label">साल का अनुभव</span>
          </div>
          <div class="stat">
            <span class="stat-number">3</span>
            <span class="stat-label">ब्रांड उपलब्ध</span>
          </div>
          <div class="stat">
            <span class="stat-number">{shop.marketArea}</span>
            <span class="stat-label">बाज़ार, {shop.city}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       §5 CTA BAND — Final conversion strip
       ═══════════════════════════════════════════════════════ -->
  <section class="cta-band">
    <div class="section-inner cta-band-inner">
      <h2 class="cta-band-title">अलमारी चाहिए? अभी बात कीजिए</h2>
      <p class="cta-band-sub">WhatsApp पर मैसेज कीजिए या फ़ोन कीजिए — भैया तुरंत जवाब देंगे</p>
      <div class="cta-band-buttons">
        <a href={whatsappUrl} class="btn btn-whatsapp cta-band-btn" target="_blank" rel="noopener">
          <svg class="wa-icon" viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp पर मैसेज कीजिए
        </a>
        <a href={`tel:${shop.whatsappNumberE164}`} class="btn btn-outline cta-band-btn cta-band-phone" target="_blank" rel="noopener">
          📞 फ़ोन कीजिए
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       §6 FOOTER
       ═══════════════════════════════════════════════════════ -->
  <footer class="site-footer">
    <div class="section-inner footer-inner">
      <div class="footer-brand">
        <h3 class="footer-shop-name">{shop.brandName}</h3>
        <p class="footer-shop-name-en">{shop.brandNameEnglish}</p>
      </div>

      <div class="footer-grid">
        <div class="footer-col">
          <h4 class="footer-col-title">पता</h4>
          <p class="footer-text">{shop.marketArea}, {shop.city}</p>
          <a href="https://maps.google.com/?q=Harringtonganj+Ayodhya" target="_blank" rel="noopener" class="footer-link">
            📍 नक्शा देखिए
          </a>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">समय</h4>
          <p class="footer-text">सोमवार–शनिवार</p>
          <p class="footer-text">सुबह 10 बजे – शाम 8 बजे</p>
          <p class="footer-text footer-sunday">रविवार बंद</p>
        </div>
        <div class="footer-col">
          <h4 class="footer-col-title">संपर्क</h4>
          <a href={`tel:${shop.whatsappNumberE164}`} class="footer-link">📞 फ़ोन कीजिए</a>
          <a href={whatsappUrl} target="_blank" rel="noopener" class="footer-link">💬 WhatsApp</a>
          <a href="/visit" class="footer-link">🏪 दुकान आइए</a>
        </div>
      </div>

      <hr class="brass-divider" />
      <p class="footer-credit">
        <span class="footer-credit-text">Powered by</span>
        <span class="footer-credit-brand">Yugma Labs</span>
      </p>
    </div>
  </footer>
</BaseLayout>

<style>
  /* ================================================================
   * §1 HERO
   * ================================================================ */
  .hero {
    position: relative;
    background: linear-gradient(
      160deg,
      var(--color-primary) 0%,
      var(--color-primary-deep) 60%,
      #2A1005 100%
    );
    color: var(--color-text-on-primary);
    padding: var(--s12) var(--s4) var(--s10);
    text-align: center;
    overflow: hidden;
  }

  /* Subtle diagonal pattern overlay */
  .hero-bg-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image: repeating-linear-gradient(
      45deg,
      transparent,
      transparent 20px,
      rgba(255,255,255,0.1) 20px,
      rgba(255,255,255,0.1) 21px
    );
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    max-width: 600px;
    margin: 0 auto;
  }

  /* Face photo with brass ring */
  .hero-photo-wrap {
    position: relative;
    display: inline-block;
    margin-bottom: var(--s6);
  }

  .hero-photo {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    border: 4px solid var(--color-accent);
    box-shadow: var(--shadow-hero);
  }

  .hero-photo-fallback {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--color-secondary), var(--color-primary));
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 4px solid var(--color-accent);
    box-shadow: var(--shadow-hero);
  }

  .hero-initials {
    font-family: var(--font-deva-display);
    font-size: 3.5rem;
    color: var(--color-text-on-primary);
  }

  .hero-photo-ring {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 2px solid var(--color-accent-glow);
    opacity: 0.4;
    pointer-events: none;
  }

  .hero-name {
    font-family: var(--font-deva-display);
    font-size: 2.5rem;
    font-weight: 400;
    line-height: 1.15;
    margin-bottom: var(--s1);
  }

  .hero-name-en {
    font-family: var(--font-en-display);
    font-size: 1rem;
    font-weight: 400;
    font-style: italic;
    opacity: 0.7;
    margin-bottom: var(--s4);
  }

  .hero-tagline {
    font-family: var(--font-deva-body);
    font-size: 1.15rem;
    opacity: 0.85;
    margin-bottom: var(--s5);
    line-height: 1.5;
  }

  /* Trust badges */
  .hero-badges {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--s1);
    font-family: var(--font-deva-body);
    font-size: 0.85rem;
    opacity: 0.75;
    margin-bottom: var(--s6);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: var(--s1);
  }

  .badge-gst {
    background: rgba(184, 134, 11, 0.25);
    padding: 2px 8px;
    border-radius: 4px;
    font-size: 0.8rem;
  }

  .badge-dot {
    opacity: 0.5;
    margin: 0 var(--s1);
  }

  /* Voice greeting */
  .hero-voice {
    margin-bottom: var(--s6);
  }

  .btn-voice {
    font-family: var(--font-deva-body);
    font-size: 0.9rem;
    font-weight: 600;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: var(--color-text-on-primary);
    padding: var(--s2) var(--s5);
    border-radius: 24px;
    cursor: pointer;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: var(--s2);
  }

  .btn-voice:hover {
    background: rgba(255, 255, 255, 0.22);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .btn-voice.playing {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  /* Hero CTAs */
  .hero-ctas {
    display: flex;
    flex-direction: column;
    gap: var(--s3);
    align-items: center;
  }

  .hero-cta {
    width: 100%;
    max-width: 320px;
    font-size: 1rem;
  }

  .hero-cta-app {
    border-color: rgba(255, 255, 255, 0.4);
    color: var(--color-text-on-primary);
  }

  .hero-cta-app:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: var(--color-text-on-primary);
    color: var(--color-text-on-primary);
  }

  .wa-icon {
    flex-shrink: 0;
  }

  /* ================================================================
   * §2 TRUST SECTION
   * ================================================================ */
  .trust-section {
    background: var(--color-bg-warmer);
    text-align: center;
  }

  .trust-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s4);
  }

  .trust-card {
    background: var(--color-surface);
    border-radius: 12px;
    padding: var(--s6) var(--s4);
    border: 1px solid var(--color-divider-solid);
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.2s;
  }

  .trust-card:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .trust-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: var(--s3);
  }

  .trust-title {
    font-family: var(--font-deva-body);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
