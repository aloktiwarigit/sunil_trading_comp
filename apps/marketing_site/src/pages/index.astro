<script define:vars={{ skuData: JSON.stringify(shop.curatedPreview), ownerName: shop.ownerName }}>
  const skus = JSON.parse(skuData);
  const voiceBtnLabel = '🎤 ' + ownerName + ' की आवाज़ सुनिए';

  function toggleVoice() {
    const audio = document.getElementById('greetingAudio');
    const btn = document.getElementById('voiceBtn');
    if (!audio || !btn) return;

    if (audio.paused) {
      audio.play().then(() => {
        btn.classList.add('playing');
        btn.textContent = '🔊 बंद कीजिए';
      }).catch(() => {});
    } else {
      audio.pause();
      audio.currentTime = 0;
      btn.classList.remove('playing');
      btn.textContent = voiceBtnLabel;
    }

    audio.addEventListener('ended', () => {
      btn.classList.remove('playing');
      btn.textContent = voiceBtnLabel;
    }, { once: true });
  }

  window.toggleVoice = toggleVoice;
</script>
