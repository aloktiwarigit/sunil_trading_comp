---
// Base layout for all marketing pages.
// Per M5.1 AC #2: <100KB initial bundle including subset Devanagari font.
// Per Constraint 4: 5 fonts only — Tiro Devanagari Hindi, Mukta, Fraunces,
// EB Garamond, DM Mono.
//
// Design system: Workshop Almanac v1.1
// Aesthetic: Artisan Industrial — warm family shopkeeper meets honest iron.
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'सुनील ट्रेडिंग कंपनी — अयोध्या की भरोसेमंद अलमारी दुकान' } = Astro.props;
---

<!doctype html>
<html lang="hi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Subset fonts via Google Fonts — Devanagari display + body -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Tiro+Devanagari+Hindi&family=Mukta:wght@400;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,700&family=EB+Garamond:wght@400;600&family=DM+Mono&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      /* ================================================================
       * Yugma Dukaan Marketing — Workshop Almanac Design System
       *
       * Aesthetic: Artisan Industrial
       * "A hand-bound 1960s North Indian shop ledger meets polished
       *  sheesham wood, with the honest weight of iron and steel."
       * ================================================================ */

      :root {
        /* ── Workshop Almanac Color Tokens (ADR-003) ── */
        --color-primary: #6B3410;
        --color-primary-deep: #4A2308;
        --color-secondary: #8B4513;
        --color-accent: #B8860B;
        --color-accent-glow: #D4A547;
        --color-background: #FAF3E7;
        --color-bg-warmer: #F5EBD7;
        --color-surface: #FFFAF0;
        --color-text-primary: #1F1611;
        --color-text-secondary: #5C4A3A;
        --color-text-muted: #8B7A6B;
        --color-text-on-primary: #FAF3E7;
        --color-divider: rgba(107, 52, 16, 0.12);
        --color-divider-solid: #E8DFD2;

        /* ── Font families (Constraint 4: 5 only) ── */
        --font-deva-display: 'Tiro Devanagari Hindi', serif;
        --font-deva-body: 'Mukta', sans-serif;
        --font-en-display: 'Fraunces', serif;
        --font-en-body: 'EB Garamond', serif;
        --font-mono: 'DM Mono', monospace;

        /* ── Spacing ── */
        --s1: 4px;
        --s2: 8px;
        --s3: 12px;
        --s4: 16px;
        --s5: 20px;
        --s6: 24px;
        --s8: 32px;
        --s10: 40px;
        --s12: 48px;
        --s16: 64px;

        /* ── Shadows (warm, never gray) ── */
        --shadow-card: 0 2px 8px rgba(74, 35, 8, 0.10);
        --shadow-card-hover: 0 4px 16px rgba(74, 35, 8, 0.18);
        --shadow-hero: 0 4px 24px rgba(0, 0, 0, 0.3);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-deva-body);
        background-color: var(--color-background);
        color: var(--color-text-primary);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: var(--color-primary);
        text-decoration: none;
      }

      img {
        max-width: 100%;
        height: auto;
      }

      /* ── Button system (48px min touch target) ── */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: var(--s2);
        min-height: 48px;
        padding: var(--s3) var(--s6);
        border-radius: 8px;
        font-family: var(--font-deva-body);
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        border: none;
        transition: all 0.2s ease;
        text-decoration: none;
      }

      .btn:hover { opacity: 0.92; transform: translateY(-1px); }
      .btn:active { transform: translateY(0); }

      .btn-primary {
        background-color: var(--color-primary);
        color: var(--color-text-on-primary);
      }

      .btn-accent {
        background-color: var(--color-accent);
        color: var(--color-text-on-primary);
      }

      .btn-outline {
        background-color: transparent;
        border: 2px solid var(--color-primary);
        color: var(--color-primary);
      }

      .btn-outline:hover {
        background-color: var(--color-primary);
        color: var(--color-text-on-primary);
      }

      .btn-whatsapp {
        background-color: #25D366;
        color: #fff;
      }

      .btn-whatsapp:hover {
        background-color: #1DA851;
      }

      /* ── Section system ── */
      .section {
        padding: var(--s12) var(--s4);
      }

      .section-inner {
        max-width: 900px;
        margin: 0 auto;
      }

      .section-title {
        font-family: var(--font-deva-display);
        font-size: 1.75rem;
        font-weight: 400;
        color: var(--color-text-primary);
        margin-bottom: var(--s2);
      }

      .section-subtitle {
        font-family: var(--font-en-display);
        font-size: 0.9rem;
        font-weight: 400;
        font-style: italic;
        color: var(--color-text-muted);
        margin-bottom: var(--s8);
      }

      /* ── Brass divider ── */
      .brass-divider {
        width: 60px;
        height: 2px;
        background: linear-gradient(90deg, var(--color-accent), var(--color-accent-glow), var(--color-accent));
        margin: var(--s6) auto;
        border: none;
      }

      /* ── Responsive ── */
      @media (min-width: 768px) {
        .section {
          padding: var(--s16) var(--s8);
        }

        .section-title {
          font-size: 2.25rem;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
